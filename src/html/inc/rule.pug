.message.hide
  | 规则を変更しました。

form.rule
  dl
    dt 预设
    dd
      select(name="预设")
        option 电脑麻将规则
      input(type="button" name="预设" value="读取")
  dl
    dt 配给原点
    dd
      input(name="配给原点" type="text" maxlength="5")
    dt 顺位点
    dd
      label.wrap
        | 1着:
        input(name="顺位点" type="text" disabled)
      label.wrap
        | 2着:
        input(name="顺位点" type="text")
      label.wrap
        | 3着:
        input(name="顺位点" type="text")
      label.wrap
        | 4着:
        input(name="顺位点" type="text")
      br
      label
        input(name="顺位点四捨五入有" type="checkbox" value="1")
        | 积分を四捨五入する
    dt 连风牌
    dd
      label
        input(name="连风牌は2符" type="radio" value="1")
        | 2符
      label
        input(name="连风牌は2符" type="radio" value="0")
        | 4符
  dl
    dt 赤牌
    dd
      label
        img(src="img/m0.gif" alt="赤ウーワン")
        input(name="赤牌" type="text" maxlength="1")
      label
        img(src="img/p0.gif" alt="赤ウーピン")
        input(name="赤牌" type="text" maxlength="1")
      label
        img(src="img/s0.gif" alt="赤ウーソー")
        input(name="赤牌" type="text" maxlength="1")
    dt 食断
    dd
      label
        input(name="食断有" type="radio" value="0")
        | 无
      label
        input(name="食断有" type="radio" value="1")
        | 有
    dt 食替
    dd
      label
        input(name="食替許可レベル" type="radio" value="0")
        | 食替无
      label
        input(name="食替許可レベル" type="radio" value="1")
        | スジ食替有
      label
        input(name="食替許可レベル" type="radio" value="2")
        | 現物食替も有
  dl
    dt 场数
    dd
      label
        input(name="场数" type="radio" value="0")
        | 一局战
      label
        input(name="场数" type="radio" value="1")
        | 东風戦
      label
        input(name="场数" type="radio" value="2")
        | 东南戦
      label
        input(name="场数" type="radio" value="4")
        | 一庄战
    dt 途中流局
    dd
      label
        input(name="途中流局有" type="radio" value="0")
        | 无
      label
        input(name="途中流局有" type="radio" value="1")
        | 有(九種九牌、四風連打、四家立直、四開槓)
    dt 流局满贯
    dd
      label
        input(name="流局满贯有" type="radio" value="0")
        | 无
      label
        input(name="流局满贯有" type="radio" value="1")
        | 有
    dt 无听宣言
    dd
      label
        input(name="无听宣言有" type="radio" value="0")
        | 无
      label
        input(name="无听宣言有" type="radio" value="1")
        | 有
    dt 无听罚符
    dd
      label
        input(name="无听罚符有" type="radio" value="0")
        | 无
      label
        input(name="无听罚符有" type="radio" value="1")
        | 有
    dt 同时和了
    dd
      label
        input(name="最大同时和了数" type="radio" value="1")
        | 头跳
      label
        input(name="最大同时和了数" type="radio" value="2")
        | ダブ荣和有(三家和は流局)
      label
        input(name="最大同时和了数" type="radio" value="3")
        | トリ荣和有
    dt 连庄方式
    dd
      label
        input(name="连庄方式" type="radio" value="0")
        | 連荘无
      label
        input(name="连庄方式" type="radio" value="1")
        | 和了连庄
      label
        input(name="连庄方式" type="radio" value="2")
        | 听牌连庄
      label
        input(name="连庄方式" type="radio" value="3")
        | 无听连庄
    dt トビ结束
    dd
      label
        input(name="トビ结束有" type="radio" value="0")
        | 无
      label
        input(name="トビ结束有" type="radio" value="1")
        | 有
    dt オーLAST止め
    dd
      label
        input(name="オーLAST止め有" type="radio" value="0")
        | 无
      label
        input(name="オーLAST止め有" type="radio" value="1")
        | 有
    dt 延长战方式
    dd
      label
        input(name="延长战方式" type="radio" value="0")
        | 延長戦无
      label
        input(name="延长战方式" type="radio" value="1")
        | 突然死亡
      label
        input(name="延长战方式" type="radio" value="2")
        | 連荘優先突然死亡
      label
        input(name="延长战方式" type="radio" value="3")
        | 4局固定
  dl
    dt 一发
    dd
      label
        input(name="一发有" type="radio" value="0")
        | 无
      label
        input(name="一发有" type="radio" value="1")
        | 有
    dt 里ドラ
    dd
      label
        input(name="里ドラ有" type="radio" value="0")
        | 无
      label
        input(name="里ドラ有" type="radio" value="1")
        | 有
    dt 杠ドラ
    dd
      label
        input(name="杠ドラ有" type="radio" value="0")
        | 无
      label
        input(name="杠ドラ有" type="radio" value="1")
        | 有
      label
        input(name="杠ドラ后加" type="checkbox" value="1")
        | 后加
    dt 杠里
    dd
      label
        input(name="杠里有" type="radio" value="0")
        | 无
      label
        input(name="杠里有" type="radio" value="1")
        | 有
    dt 自摸番无立直
    dd
      label
        input(name="自摸番无立直有" type="radio" value="0")
        | 无
      label
        input(name="自摸番无立直有" type="radio" value="1")
        | 有
    dt 立直後的暗槓
    dd
      label
        input(name="立直後暗槓許可レベル" type="radio" value="0")
        | すべて的暗槓不可
      label
        input(name="立直後暗槓許可レベル" type="radio" value="1")
        | 牌姿的変わる暗槓不可
      label
        input(name="立直後暗槓許可レベル" type="radio" value="2")
        | 待ち的変わる暗槓不可
  dl
    dt 役满的複合
    dd
      label
        input(name="役满的複合有" type="radio" value="0")
        | 无
      label
        input(name="役满的複合有" type="radio" value="1")
        | 有
    dt ダブル役满
    dd
      label
        input(name="ダブル役满有" type="radio" value="0")
        | 无
      label
        input(name="ダブル役满有" type="radio" value="1")
        | 有(国士无双十三面、四暗刻单骑、大四喜、纯正九莲宝灯)
    dt 数え役满
    dd
      label
        input(name="数え役满有" type="radio" value="0")
        | 无
      label
        input(name="数え役满有" type="radio" value="1")
        | 有
    dt 役满パオ
    dd
      label
        input(name="役满パオ有" type="radio" value="0")
        | 无
      label
        input(name="役满パオ有" type="radio" value="1")
        | 有(大三元、大四喜)
    dt 切上满贯
    dd
      label
        input(name="切上满贯有" type="radio" value="0")
        | 无
      label
        input(name="切上满贯有" type="radio" value="1")
        | 有

  input(type="submit" value="変更")
